"scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:admin": "pnpm -F @swm-pro/admin dev",
    "dev:api": "pnpm -F @swm-pro/api dev",
    "dev:worker": "pnpm -F @swm-pro/worker dev",
    "build": "pnpm -r build",
    "build:admin": "pnpm -F @swm-pro/admin build",
    "build:api": "nest build api && (cp -r dist/apps/api/* dist/ 2>/dev/null || echo 'Already flat')",
    "start:api": "node --experimental-specifier-resolution=node dist/main.js",
    "start": "node --experimental-specifier-resolution=node dist/main.js",
    "check": "pnpm -r check",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "db:push": "pnpm -F @swm-pro/db push",
    "db:seed": "pnpm -F @swm-pro/db seed"
  },
